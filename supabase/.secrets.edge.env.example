# Copie este ficheiro para supabase/.secrets.edge.env (ignorado pelo git), substitua os valores e execute:
#   npm run supabase:secrets:edge
#
# CORS das Edge Functions (origens permitidas, separadas por vírgula). Se omitir no Supabase Secrets,
# usam-se valores por defeito em `supabase/functions/_shared/cors.ts` (localhost + Vercel).
# EDGE_FUNCTION_ALLOWED_ORIGINS=https://seudominio.com,https://rh-ambiental-sistema.vercel.app
#
# Outlook/Hotmail: conta com 2FA + senha de app (App password)
OUTLOOK_USER=faturamentorgambiental@hotmail.com
OUTLOOK_APP_PASSWORD=substitua_pela_senha_de_app

# Opcional — remetente
# NF_EMAIL_FROM=RG Ambiental <faturamentorgambiental@hotmail.com>

# Se preferir Resend em vez de Outlook, comente as linhas OUTLOOK_* acima e use:
# RESEND_API_KEY=re_sua_chave

# Opcional — Edge Function admin-set-user-pages: e-mails extra (minúsculos) que podem editar
# `usuarios.paginas_permitidas`, além da lista base no código. Separados por vírgula ou ponto e vírgula.
# PAGINAS_BYPASS_EMAILS=admin@empresa.com
