# Copie este ficheiro para supabase/.secrets.edge.env (ignorado pelo git), substitua os valores e execute:
#   npm run supabase:secrets:edge
#
# CORS das Edge Functions (origens permitidas, separadas por vírgula). Se omitir no Supabase Secrets,
# usam-se valores por defeito em `supabase/functions/_shared/cors.ts` (localhost + Vercel).
# EDGE_FUNCTION_ALLOWED_ORIGINS=https://seudominio.com,https://rh-ambiental-sistema.vercel.app
#
# Outlook/Hotmail: conta com 2FA + senha de app (App password)
OUTLOOK_USER=faturamentorgambiental@hotmail.com
OUTLOOK_APP_PASSWORD=substitua_pela_senha_de_app

# Opcional — servidor SMTP (Microsoft pode dar timeout a partir do Supabase; teste ou use Resend).
# OUTLOOK_SMTP_HOST=smtp-mail.outlook.com
# OUTLOOK_SMTP_PORT=465
# OUTLOOK_SMTP_TLS=true

# Escolha do provedor: auto | outlook | resend
# - auto: se OUTLOOK_* e RESEND_* existirem, usa Resend (evita SMTP lento). Só Outlook se não houver Resend.
# - resend / outlook: força um dos dois.
EMAIL_PROVIDER=auto

# Opcional — remetente (obrigatório em produção: domínio verificado na Resend, ex. rgambiental.com.br)
# NF_EMAIL_FROM=RG Ambiental <faturamento2@rgambiental.com.br>

# Opcional — respostas dos clientes vão para esta caixa (pode ser @hotmail.com; não precisa estar na Resend)
# NF_EMAIL_REPLY_TO=faturamentorgambiental@hotmail.com

# Resend (HTTPS) — recomendado nas Edge Functions; com EMAIL_PROVIDER=auto é escolhido automaticamente se existir junto com OUTLOOK_*
# RESEND_API_KEY=re_sua_chave

# Para forçar só Resend (ignora Outlook):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_sua_chave

# Opcional — Edge Function admin-set-user-pages: e-mails extra (minúsculos) que podem editar
# `usuarios.paginas_permitidas`, além da lista base no código. Separados por vírgula ou ponto e vírgula.
# PAGINAS_BYPASS_EMAILS=admin@empresa.com
