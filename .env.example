# Copie para .env local ou configure estes nomes no painel da Vercel (Environment Variables).
# Valores em: Supabase → Project Settings → API

# --- URL oficial em produção (única a divulgar; ver também src/lib/officialSiteUrl.ts) ---
# Na Vercel: o alias de produção deve ser https://rh-ambiental-sistema.vercel.app (deploy: npm run deploy:vercel).
# No Supabase → Authentication → URL Configuration: inclua esta origem em Site URL e Redirect URLs (ex.: https://rh-ambiental-sistema.vercel.app/** ).
# VITE_APP_ORIGIN=https://rh-ambiental-sistema.vercel.app

# Versão no UI (fim do número): quem lança a build. V = Vinicius, R = Rafael. Definir no `.env` local e na Vercel (Production).
# Sem isto, a versão mostra só o semver do package.json (ex.: 1.0.0).
# APP_VERSION_AUTHOR=V

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable

# IMPORTANTE: nunca use nem commite a Service Role Key no frontend.
# Se existir SUPABASE_SERVICE_ROLE_KEY no seu `.env`, remova e gere uma nova no Supabase.

# Suporte técnico (balão → chat interno). Opcional: UUID do utilizador em Auth / `usuarios` (tem prioridade sobre o e-mail)
# VITE_SUPORTE_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Se não definir o UUID, usa-se o e-mail para localizar o perfil activo:
# VITE_SUPORTE_EMAIL=cavalcantersc07@gmail.com

# Opcional — e-mails (minúsculos) que ignoram `paginas_permitidas` além da lista base no código.
# Lista separada por vírgula ou ponto e vírgula. Em branco = só a lista base (comportamento anterior).
# VITE_PAGINAS_BYPASS_EMAILS=admin@empresa.com,outro@empresa.com

# Opcional (opt-in) — limita `vw_faturamento_resumo` às coletas com created_at nos últimos N dias (menos dados por pedido).
# Sem esta variável, carrega todo o histórico paginado (comportamento por defeito).
# VITE_FATURAMENTO_RESUMO_DESDE_DIAS=120

# Edge Functions (segredos Supabase, não Vite): ver supabase/.secrets.edge.env.example — PAGINAS_BYPASS_EMAILS, EDGE_FUNCTION_ALLOWED_ORIGINS

# Opcional — deploy produção Vercel sem browser:
#   npm run deploy:vercel:r  (sufixo R na versão / Rafael)  |  deploy:vercel:v (Vinicius)  |  deploy:vercel (sem --build-env extra)
# Token: https://vercel.com/account/tokens — nunca commitar. Podes usar `.env` ou `.env.local` (o deploy carrega os dois).
# Uma vez: npx vercel link
# VERCEL_TOKEN=
# VERCEL_ORG_ID=     # só se não usares .vercel/ após link
# VERCEL_PROJECT_ID=

# Opcional — scripts locais (migrações DDL via `npm run db:apply:sql -- <ficheiro.sql>`)
# Senha em: Supabase → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=
# Ou URI completa:
# DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# --- Edge Function send-nf-email (defina no Supabase: Project Settings → Edge Functions → Secrets, não no Vite) ---
# Gmail (prioridade sobre Resend se GMAIL_USER + GMAIL_APP_PASSWORD estiverem definidos):
# GMAIL_USER=conta@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Resend (alternativa):
# RESEND_API_KEY=re_...
# Opcional — remetente (deve ser permitido pelo Gmail ou domínio verificado na Resend):
# NF_EMAIL_FROM=RG Ambiental <nf@seudominio.com>
#
# Aplicar estes segredos ao projeto remoto (CLI logado: supabase login):
#   1) Copie supabase/.secrets.edge.env.example para supabase/.secrets.edge.env e preencha.
#   2) npm run supabase:link   (uma vez, por projeto)
#   3) npm run supabase:secrets:edge
#   4) npm run functions:deploy:send-nf-email
