{
  "name": "rg-ambiental-sistema",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --port 4173 --strictPort",
    "build": "npm run build:brand && tsc -b && vite build",
    "build:brand": "node scripts/generate-brand-assets.mjs",
    "process:wordmark": "node scripts/process-wordmark-import.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview --port 4173 --strictPort",
    "seed:simulacao-coletas": "tsx scripts/seed-simulacao-coletas.ts",
    "seed:fluxo-completo-20": "tsx scripts/seed-fluxo-completo-20.ts",
    "seed:historico-200-finalizadas": "tsx scripts/seed-historico-200-finalizadas.ts",
    "seed:historico-500-finalizadas-60d": "tsx scripts/seed-historico-500-finalizadas-60d.ts",
    "seed:motoristas-caminhoes": "tsx scripts/seed-motoristas-caminhoes.ts",
    "seed:clientes-brasil-150": "tsx scripts/seed-clientes-brasil-150.ts",
    "reset:clientes-e-seed-200": "tsx scripts/reset-clientes-e-seed-demo-200.ts --yes",
    "seed:5-fila-faturamento": "tsx scripts/seed-5-coletas-fila-faturamento.ts",
    "seed:2000-coletas-finalizadas-multimes": "tsx scripts/seed-2000-coletas-finalizadas-multimes.ts",
    "reset:coletas-operacao": "tsx scripts/reset-coletas-operacao.ts",
    "reset:dados-teste": "tsx scripts/reset-coletas-operacao.ts --yes",
    "reset:e-seed-coletas-50": "tsx scripts/reset-coletas-operacao.ts --yes && tsx scripts/seed-simulacao-coletas.ts",
    "reset:e-seed-fluxo-20": "tsx scripts/reset-coletas-operacao.ts --yes && tsx scripts/seed-fluxo-completo-20.ts",
    "db:apply:sql": "tsx scripts/apply-supabase-sql.ts",
    "db:apply:clientes-etapa1": "tsx scripts/apply-supabase-sql.ts supabase/migrations/20260413120000_clientes_enderecos_email_nf.sql",
    "db:apply:clientes-status-datas": "tsx scripts/apply-supabase-sql.ts supabase/migrations/20260427140000_clientes_status_datas.sql",
    "db:apply:faturamento-view": "tsx scripts/apply-supabase-sql.ts supabase/sql_editor_vw_faturamento_resumo.sql",
    "supabase": "supabase",
    "functions:deploy:admin-update": "supabase functions deploy admin-update-user",
    "functions:deploy:admin-delete": "supabase functions deploy admin-delete-user",
    "functions:deploy:admin-set-user-pages": "supabase functions deploy admin-set-user-pages",
    "functions:deploy:admin-all": "supabase functions deploy admin-create-user && supabase functions deploy admin-update-user && supabase functions deploy admin-delete-user && supabase functions deploy admin-set-user-pages",
    "functions:deploy:send-nf-email": "supabase functions deploy send-nf-email",
    "supabase:link": "supabase link",
    "supabase:secrets:edge": "supabase secrets set --env-file supabase/.secrets.edge.env",
    "deploy:vercel": "node scripts/deploy-vercel.mjs",
    "admin:create-pateta": "tsx scripts/create-admin-user.ts --name Pateta --email pateta@empresa.local --cargo administrador",
    "admin:create-teste": "tsx scripts/create-admin-user.ts --name Teste --email teste@rgambiental.com --cargo administrador",
    "import:clientes:xlsx": "tsx scripts/import-clientes-from-xlsx.ts",
    "import:motoristas-veiculos:rg": "tsx scripts/import-motoristas-veiculos-rg-xlsx.ts",
    "db:cleanup:motoristas-caminhoes": "tsx scripts/apply-supabase-sql.ts supabase/sql_cleanup_motoristas_caminhoes_tudo.sql",
    "cleanup:motoristas-caminhoes": "tsx scripts/cleanup-motoristas-caminhoes.ts --yes",
    "seed:motoristas-rg-lista": "tsx scripts/seed-motoristas-rg-lista.ts",
    "seed:caminhoes-rg-frota": "tsx scripts/seed-caminhoes-rg-frota.ts",
    "report:clientes:duplicados": "tsx scripts/report-clientes-duplicados.ts",
    "dedupe:clientes:cnpj": "tsx scripts/dedupe-clientes-by-cnpj.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "@svg-country-maps/brazil": "^1.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "supabase": "^2.85.0",
    "to-ico": "1.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  }
}
